{
  "name": "snaplink",
  "version": "1.0.0",
  "description": "A fast URL shortener service with analytics, QR codes, and custom aliases",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts"
  },
  "keywords": ["url-shortener", "redis", "typescript", "express", "analytics"],
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "nanoid": "^3.3.7",
    "qrcode": "^1.5.4",
    "redis": "^4.7.0",
    "ua-parser-js": "^1.0.39"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/qrcode": "^1.5.5",
    "@types/ua-parser-js": "^0.7.39",
    "@types/node": "^20.14.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
